# Farminsight self-hosted runtime
# Copy to .env next to the release bundle and replace every example value.

HOST=0.0.0.0
PORT=8080
FRONTEND_DIST_DIR=frontend/dist
MIGRATIONS_DIR=backend/migrations
SELF_URL=https://farminsight.example.com
ALLOWED_CORS_ORIGIN=https://farminsight.example.com

# PostgreSQL is required for every persistent record.
DATABASE_URL=postgresql://farminsight:replace-me@postgres.example.com:5432/farminsight?sslmode=require
DATABASE_MAX_CONNECTIONS=5
# Optional override. Leave unset to use sslmode from DATABASE_URL.
# DATABASE_SSL_MODE=require

# Object storage is required for committed CSV files.
OBJECT_STORAGE_ENDPOINT_URL=https://fly.storage.tigris.dev
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=replace-with-bucket
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-key
OBJECT_STORAGE_PREFIX=farminsight

# Ideavibes auth service. Do not configure Google OAuth directly in this app.
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_hp-prince-e004-farminsight-83c2db
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Ideavibes email proxy. Leave both unset only if invite email delivery should be disabled.
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=replace-with-email-app-token
