# Server
HOST=0.0.0.0
PORT=8080
FRONTEND_DIST_DIR=frontend/dist
MIGRATIONS_DIR=backend/migrations
SELF_URL=https://example.mctai.app
ALLOWED_CORS_ORIGIN=https://example.mctai.app

# PostgreSQL
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/app_db?sslmode=disable
DATABASE_MAX_CONNECTIONS=5
# Optional override. Leave unset to use sslmode from DATABASE_URL.
# DATABASE_SSL_MODE=disable

# Object storage
OBJECT_STORAGE_ENDPOINT_URL=https://fly.storage.tigris.dev
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=example-bucket
OBJECT_STORAGE_ACCESS_KEY_ID=example-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=example-secret-key
OBJECT_STORAGE_PREFIX=uploads

# Ideavibes auth service
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_example
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Legacy fallback only. New code should verify the mctai_session cookie instead of issuing app JWTs.
JWT_SECRET=replace-with-development-only-secret

# Ideavibes email proxy
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=email_app_example
